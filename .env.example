# ============================================================
# .env.example — Template konfigurasi untuk vending_api
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai
# JANGAN commit file .env ke GitHub!
# ============================================================

# --- Database (SQL Server) ---
DB_SERVER=YOURPC\SQLEXPRESS
DB_NAME=db_vending_machine
DB_USERNAME=sa
DB_PASSWORD=your_db_password_here

# --- Email (Gmail SMTP untuk OTP) ---
# Gunakan Gmail App Password (bukan password Gmail biasa)
# Cara buat App Password: myaccount.google.com > Security > 2-Step Verification > App passwords
EMAIL_SENDER=youraddress@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here
